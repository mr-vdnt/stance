rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Path Variable Hardening (global helpers)
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Conversations
    match /conversations/{convId} {
      function isValidConversation(data) {
        return data.userId is string
          && data.title is string
          && data.title.size() <= 200
          && (data.get('preferredModel', '') is string)
          && (data.get('ethicalMode', 'utilitarian') in ['utilitarian', 'equal-value', 'duty-based', 'randomized', 'interpretive'])
          && (data.get('biasThreshold', 0.5) is number)
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
      }

      allow create: if isSignedIn() 
        && isValidId(convId)
        && incoming().userId == request.auth.uid
        && isValidConversation(incoming())
        && incoming().keys().hasAll(['userId', 'title', 'preferredModel', 'ethicalMode', 'createdAt', 'updatedAt'])
        && incoming().keys().size() <= 7;
        
      allow get: if isSignedIn() 
        && isValidId(convId)
        && (resource.data.userId == request.auth.uid || resource.data.userId == 'anonymous');

      allow list: if isSignedIn()
        && (resource.data.userId == request.auth.uid || resource.data.userId == 'anonymous');
      
      allow update: if isOwner(resource.data.userId) 
        && isValidId(convId)
        && isValidConversation(incoming())
        && incoming().diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'title', 'preferredModel', 'ethicalMode', 'biasThreshold']);

      allow delete: if isOwner(resource.data.userId);
    }

    // Messages
    match /messages/{msgId} {
      function isValidBiasScores(scores) {
        return scores.toxicity is number
          && scores.genderBias is number
          && scores.racialBias is number
          && scores.politicalBias is number
          && scores.ageism is number
          && scores.ableism is number
          && scores.socialBias is number
          && scores.economicBias is number
          && scores.logical is number
          && scores.overallScore is number
          && scores.biasVariance is number
          && scores.confidenceScores is map
          && scores.confidenceScores.toxicity is number
          && scores.confidenceScores.genderBias is number
          && scores.confidenceScores.racialBias is number
          && scores.confidenceScores.politicalBias is number
          && scores.confidenceScores.ageism is number
          && scores.confidenceScores.ableism is number
          && scores.confidenceScores.socialBias is number
          && scores.confidenceScores.economicBias is number
          && scores.confidenceScores.logical is number
          && (scores.get('summary', '') is string);
      }

    function isValidAttachment(attachment) {
      return attachment.id is string
        && attachment.name is string
        && attachment.name.size() <= 500
        && attachment.type is string
        && attachment.url is string
        && attachment.url.size() <= 2000
        && attachment.size is number
        && (attachment.get('previewUrl', '') is string);
    }

    function isValidOptimizationReport(report) {
      return report is map
        && report.improved_response is string
        && report.indicator_scores_before is map
        && report.indicator_scores_after is map
        && report.changes_made is list
        && report.rationale_summary is string;
    }

    function isValidMessage(data) {
      return data.conversationId is string
        && data.role in ['user', 'assistant']
        && data.content is string
        && data.content.size() <= 10000
        && (data.get('attachments', null) == null || (data.attachments is list && data.attachments.size() <= 10 && (data.attachments.size() == 0 || isValidAttachment(data.attachments[0]))))
        && (data.get('originalContent', '') is string)
        && (data.get('isCorrected', false) is bool)
        && (data.get('isDeleted', false) is bool)
        && (data.get('isGloballyDeleted', false) is bool)
        && (data.get('deletedAt', null) == null || data.get('deletedAt', null) is timestamp)
        && (data.get('parentId', null) == null || isValidId(data.parentId))
        && (data.get('version', 3) is int)
        && (data.get('feedback', null) == null || data.get('feedback', null) in ['up', 'down'])
        && (data.get('biasScores', null) == null || isValidBiasScores(data.biasScores))
        && (data.get('optimizationReport', null) == null || isValidOptimizationReport(data.optimizationReport))
        && (data.get('suggestions', null) == null || (data.suggestions is list && data.suggestions.size() <= 3))
        && (data.get('searchSuggestions', null) == null || (data.searchSuggestions is list && data.searchSuggestions.size() <= 5))
        && data.createdAt is timestamp;
    }

      function canWriteMessage(convId) {
        let conv = get(/databases/$(database)/documents/conversations/$(convId)).data;
        return isOwner(conv.userId);
      }

      allow create: if isSignedIn()
        && isValidId(msgId)
        && isValidMessage(incoming())
        && canWriteMessage(incoming().conversationId);
        
      allow get: if isSignedIn() 
        && isValidId(msgId)
        && canWriteMessage(resource.data.conversationId);

      allow list: if isSignedIn()
        && canWriteMessage(resource.data.conversationId);
      
      allow update: if isSignedIn() 
        && isValidId(msgId)
        && isValidMessage(incoming())
        && canWriteMessage(resource.data.conversationId)
        && (
          (incoming().diff(resource.data).affectedKeys().hasOnly(['feedback']))
          ||
          (incoming().diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt', 'content']) && incoming().isDeleted == true)
          ||
          (incoming().diff(resource.data).affectedKeys().hasOnly(['biasScores']))
          ||
          (incoming().diff(resource.data).affectedKeys().hasOnly(['optimizationReport', 'content', 'isCorrected']))
          ||
          (incoming().diff(resource.data).affectedKeys().hasOnly(['suggestions']))
          ||
          (incoming().diff(resource.data).affectedKeys().hasOnly(['searchSuggestions']))
        );

      allow delete: if isSignedIn() 
        && isValidId(msgId)
        && canWriteMessage(resource.data.conversationId);
    }

    // Feedback
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.userId == request.auth.uid
          && data.messageId is string
          && data.type in ['up', 'down']
          && (data.get('comment', '') is string)
          && data.createdAt is timestamp;
      }

      allow create: if isSignedIn()
        && isValidId(feedbackId)
        && isValidFeedback(incoming());
      
      allow read: if isOwner(resource.data.userId);
    }

    // User Persona / Profiles
    match /users/{docId} {
      function isValidUser(data) {
        return data.userId is string
          && (data.get('name', '') is string)
          && (data.get('role', '') is string)
          && (data.get('bio', '') is string)
          && (data.get('profession', '') is string)
          && (data.get('defaultBiasThreshold', 0.5) is number)
          && (data.get('updatedAt', null) == null || data.get('updatedAt', null) is timestamp);
      }

      allow create: if isSignedIn()
        && incoming().userId == request.auth.uid
        && isValidUser(incoming());

      allow get, list: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow update: if isOwner(resource.data.userId)
        && incoming().userId == resource.data.userId
        && isValidUser(incoming());
    }

    // Test collection
    match /test/connection {
      allow read: if true;
    }
  }
}
